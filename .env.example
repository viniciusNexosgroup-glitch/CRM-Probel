# ===================== Supabase =====================
# Encontre estes valores em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Use APENAS em rotas de servidor / webhook. Nunca exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ===================== Evolution API =====================
# URL base da sua instância Evolution (sem barra no final)
EVOLUTION_API_URL=https://evolution.seudominio.com
# API key global definida na variável AUTHENTICATION_API_KEY do Evolution
EVOLUTION_API_KEY=troque-por-uma-chave-forte
# Nome da instância que será criada para este CRM
EVOLUTION_INSTANCE_NAME=crm-probel

# ===================== App =====================
# URL pública usada pelo webhook da Evolution para chamar este app
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret que o webhook precisa enviar no header X-Webhook-Secret (gere com: openssl rand -hex 32)
EVOLUTION_WEBHOOK_SECRET=gere-um-secret-aleatorio-de-64-chars
